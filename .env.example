# ============================================================
# Primed API - Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env with real secrets to version control
# ============================================================

# ------------------------------------------------------------
# Supabase Configuration (REQUIRED)
# ------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ------------------------------------------------------------
# JWT Authentication (REQUIRED)
# ------------------------------------------------------------
USE_LOCAL_JWT_VERIFICATION=true
JWKS_CACHE_TTL_SECONDS=3600
JWT_AUDIENCE=authenticated
JWT_LEEWAY_SECONDS=10

# ------------------------------------------------------------
# Analytics (OPTIONAL)
# ------------------------------------------------------------
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------
API_V1_PREFIX=/api/v1
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://localhost:4173

# ------------------------------------------------------------
# Google Gemini API (REQUIRED for LLM features)
# ------------------------------------------------------------
# For AI Studio (API key-based authentication)
GOOGLE_API_KEY=your-google-api-key-here

# For Vertex AI (Service Account-based authentication)
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ------------------------------------------------------------
# Voice Agent Configuration (ADK/Gemini Live)
# ------------------------------------------------------------
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-09-2025
GEMINI_LIVE_VOICE=
VOICE_SESSION_MAX_DURATION_MINUTES=25
VOICE_SESSION_HARD_LIMIT_MINUTES=20
VOICE_SESSION_WARNING_MINUTES_BEFORE_HARD_LIMIT=3
# Max concurrent sessions: 50 for AI Studio, 1000+ for Vertex AI
VOICE_SESSION_MAX_CONCURRENT=1000

# ADK Voice Agent Feature Flags (all disabled by default)
# Session resumption: transparent WebSocket reconnect at ~10-min connection timeout.
# Required alongside VOICE_ENABLE_CONTEXT_COMPRESSION for 25-min sessions.
VOICE_ENABLE_SESSION_RESUMPTION=false
# Context window compression: removes Vertex AI 10-min session cap.
# Always pair with VOICE_ENABLE_SESSION_RESUMPTION=true.
VOICE_ENABLE_CONTEXT_COMPRESSION=false
# Proactive audio: model only responds when appropriate; avoids background noise.
VOICE_ENABLE_PROACTIVITY=false
# Affective dialog: adapts tone based on user's emotional expressions.
# WARNING (Vertex AI docs): can produce unexpected results. Test in staging first.
VOICE_ENABLE_AFFECTIVE_DIALOG=false

# ------------------------------------------------------------
# LLM Provider Configuration
# ------------------------------------------------------------

# Model for feedback evaluation
LLM_FEEDBACK_MODEL=gemini-2.0-flash-exp

# Model for drill selection
LLM_DRILL_SELECTION_MODEL=gemini-2.0-flash-exp

# Single fallback model for text LLM calls (used only if primary model fails)
LLM_FALLBACK_MODEL=

# ------------------------------------------------------------
# Opik Observability (OPTIONAL)
# ------------------------------------------------------------
OPIK_API_KEY=
OPIK_WORKSPACE=primed-hackathon
OPIK_PROJECT_NAME=primed-skill-eval
OPIK_ENABLED=false
OPIK_USE_PROMPTS=false
